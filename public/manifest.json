      "url": "/#directory",
      "icons": [
        {
          "src": "data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 96 96'><rect width='96' height='96' fill='%232563eb' rx='10'/><text x='48' y='65' text-anchor='middle' font-size='60' fill='white'>🔍</text></svg>",
          "sizes": "96x96",
          "type": "image/svg+xml"
        }
      ]
    },
    {
      "name": "Add Business",
      "short_name": "Add Business",
      "description": "List your business",
      "url": "/add-business",
      "icons": [
        {
          "src": "data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 96 96'><rect width='96' height='96' fill='%2310b981' rx='10'/><text x='48' y='65' text-anchor='middle' font-size='60' fill='white'>➕</text></svg>",
          "sizes": "96x96",
          "type": "image/svg+xml"
        }
      ]
    },
    {
      "name": "Categories",
      "short_name": "Categories",
      "description": "Browse business categories",
      "url": "/#categories",
      "icons": [
        {
          "src": "data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 96 96'><rect width='96' height='96' fill='%23f59e0b' rx='10'/><text x='48' y='65' text-anchor='middle' font-size='60' fill='white'>📂</text></svg>",
          "sizes": "96x96",
          "type": "image/svg+xml"
        }
